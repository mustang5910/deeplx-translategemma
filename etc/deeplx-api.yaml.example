Name: deeplx-api
Host: 0.0.0.0
Port: 8888
Model: translategemma
OpenAIBaseURL: http://127.0.0.1:12434/v1
OpenAIKey: "skkk"
# Prompt 是发送给 OpenAI 模型的翻译提示词模板。
# 模板变量: {{.Text}} - 待翻译文本, {{.TargetLang}} - 目标语言名称
# 不填则使用代码内置的默认模板。
# Prompt: "Translate the following text into {{.TargetLang}}. Note that you should only output the translated result without any additional explanation:\n\n{{.Text}}\n"
MaxConcurrent: 10
# MaxRetries: OpenAI API 调用失败时的最大重试次数，设为 0 则不重试（默认）。
# 重试采用指数退避策略，间隔为 1s/2s/4s/8s... 上限 30s，并带有随机抖动。
MaxRetries: 0
